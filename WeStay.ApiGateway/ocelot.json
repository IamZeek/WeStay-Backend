{
  // Single source of truth for Gateway routing. Ports match each service's
  // launchSettings.json (HTTPS): Auth 7019, Listing 7002, Booking 7292,
  // Messaging 7179, Notification 7284. Routes are path-preserving (Upstream == Downstream).
  //
  // Auth model: routes that carry "AuthenticationOptions" are validated AT THE GATEWAY
  // using the shared "Bearer" scheme (unified Jwt Key/Issuer/Audience). Routes without it
  // are proxied with the Authorization header forwarded, and the downstream service enforces
  // its own per-endpoint [Authorize]/[AllowAnonymous]. Public reads and the anonymous
  // auth endpoints (register/login) are intentionally left open at the gateway.
  "Routes": [

    // ---- AuthService (7019) ----
    // Admin-only management endpoints (e.g. PUT /api/auth/users/{id}/role). The gateway enforces
    // the role here via Ocelot's RouteClaimsRequirement against the "role" claim; AuthService also
    // enforces [Authorize(Roles="Admin")] as the authoritative backstop. This more-specific route
    // must precede the general /api/auth/{everything} route below.
    {
      "DownstreamPathTemplate": "/api/auth/users/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7019 } ],
      "UpstreamPathTemplate": "/api/auth/users/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] },
      "RouteClaimsRequirement": { "role": "Admin" }
    },

    // Admin moderation surface (KYC verifications): same Admin gateway-gating as /users/* above.
    // AuthService also enforces [Authorize(Roles="Admin")] as the authoritative backstop.
    {
      "DownstreamPathTemplate": "/api/auth/admin/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7019 } ],
      "UpstreamPathTemplate": "/api/auth/admin/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] },
      "RouteClaimsRequirement": { "role": "Admin" }
    },

    // No gateway-level auth: register/login/external-login are anonymous; AuthService
    // enforces [Authorize] on profile/change-password/become-host/OTP itself.
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7019 } ],
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "OPTIONS" ]
    },

    // ---- ListingService (7002) ----
    // Admin moderation endpoints (GET /api/listings/admin/all, POST /api/listings/{id}/admin/
    // deactivate|reactivate) ride these existing wildcard routes (GET open / writes Bearer) and are
    // gated at the service via [Authorize(Roles="Admin")] — same approach as BookingService /jobs/*.
    // Public reads: GetListing and the /price lookup are [AllowAnonymous].
    {
      "DownstreamPathTemplate": "/api/listings/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7002 } ],
      "UpstreamPathTemplate": "/api/listings/{everything}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    },
    // Writes (create/update/delete/status) require a valid token — validated at the gateway.
    {
      "DownstreamPathTemplate": "/api/listings/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7002 } ],
      "UpstreamPathTemplate": "/api/listings/{everything}",
      "UpstreamHttpMethod": [ "POST", "PUT", "DELETE", "PATCH" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] }
    },
    // Search is public.
    {
      "DownstreamPathTemplate": "/api/search/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7002 } ],
      "UpstreamPathTemplate": "/api/search/{everything}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    },

    // ---- BookingService (7292) ----
    // Admin platform-fee config: Admin-gated at the gateway (same pattern as /api/auth/admin/*)
    // and at the service. Must precede the general /api/bookings + availability routes (different
    // prefix, so no ordering conflict, but kept here with its host service).
    {
      "DownstreamPathTemplate": "/api/admin/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7292 } ],
      "UpstreamPathTemplate": "/api/admin/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] },
      "RouteClaimsRequirement": { "role": "Admin" }
    },
    // Admin oversight (GET /api/bookings/admin/all) and the /jobs/* triggers ride these existing
    // wildcard routes and are gated at the service via [Authorize(Roles="Admin")].
    // Availability reads are [AllowAnonymous].
    {
      "DownstreamPathTemplate": "/api/bookings/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7292 } ],
      "UpstreamPathTemplate": "/api/bookings/{everything}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    },
    // Create/cancel bookings require a valid token — validated at the gateway.
    {
      "DownstreamPathTemplate": "/api/bookings/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7292 } ],
      "UpstreamPathTemplate": "/api/bookings/{everything}",
      "UpstreamHttpMethod": [ "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] }
    },

    // ---- Payments (BookingService 7292) ----
    // The SafePay webhook MUST be public (SafePay has no WeStay JWT); it is HMAC-signature-gated at
    // the service. This more-specific route precedes the Bearer-gated payments route below.
    {
      "DownstreamPathTemplate": "/api/payments/webhook",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7292 } ],
      "UpstreamPathTemplate": "/api/payments/webhook",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    },
    // Guest payment initiate/refund + booking payment view — Bearer-validated at the gateway.
    {
      "DownstreamPathTemplate": "/api/payments/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7292 } ],
      "UpstreamPathTemplate": "/api/payments/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] }
    },
    // SafePay browser redirect landing pages (/payment/success, /payment/cancel). Public (the redirect
    // carries no JWT); GET only. Covers both success + cancel via the wildcard.
    {
      "DownstreamPathTemplate": "/payment/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7292 } ],
      "UpstreamPathTemplate": "/payment/{everything}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    },

    // ---- MessagingService (7179) ----
    // Conversations and messages are fully [Authorize] — validated at the gateway.
    {
      "DownstreamPathTemplate": "/api/conversations/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7179 } ],
      "UpstreamPathTemplate": "/api/conversations/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] }
    },
    {
      "DownstreamPathTemplate": "/api/messages/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7179 } ],
      "UpstreamPathTemplate": "/api/messages/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] }
    },
    // File upload requires auth in the service; download is anonymous, so left open at the gateway.
    {
      "DownstreamPathTemplate": "/api/fileupload/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7179 } ],
      "UpstreamPathTemplate": "/api/fileupload/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ]
    },

    // ---- NotificationService (7284) ----
    // SMS endpoints (NotificationService enforces [Authorize]; send-verification is anonymous).
    // NOTE: the internal /api/notifications/* email+SMS trigger endpoints are deliberately
    // NOT routed here — they are service-to-service only (see PROJECT_STATUS.md security note).
    {
      "DownstreamPathTemplate": "/api/sms/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7284 } ],
      "UpstreamPathTemplate": "/api/sms/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ]
    },

    // ---- ReviewService (7084) ----
    // Public reads: listing reviews + summary (user-reviews reads are authorized by the service).
    {
      "DownstreamPathTemplate": "/api/reviews/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7084 } ],
      "UpstreamPathTemplate": "/api/reviews/{everything}",
      "UpstreamHttpMethod": [ "GET", "OPTIONS" ]
    },
    // Writes (create/edit/delete a review) require a valid token — validated at the gateway.
    {
      "DownstreamPathTemplate": "/api/reviews/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 7084 } ],
      "UpstreamPathTemplate": "/api/reviews/{everything}",
      "UpstreamHttpMethod": [ "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": { "AuthenticationProviderKey": "Bearer", "AllowedScopes": [] }
    }
  ],

  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7087"
  }
}
